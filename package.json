{
  "name": "live-project-intelligence-dashboard",
  "version": "1.0.0",
  "description": "Real-time project intelligence dashboard for engineering teams",
  "type": "module",
  "scripts": {
    "dev": "concurrently \"pnpm dev:server\" \"pnpm dev:ui\"",
    "dev:server": "tsx watch server/src/index.ts",
    "dev:ui": "cd ui && vite",
    "build": "cd ui && vite build",
    "typecheck": "tsc --noEmit",
    "start": "node dist/server/index.js"
  },
  "dependencies": {
    "chokidar": "^3.6.0",
    "cors": "^2.8.5",
    "escomplex": "^2.0.0-alpha",
    "express": "^4.19.2",
    "fast-glob": "^3.3.3",
    "recharts": "^2.12.7",
    "simple-git": "^3.24.0",
    "ws": "^8.17.0"
  },
  "devDependencies": {
    "@types/cors": "^2.8.17",
    "@types/express": "^4.17.21",
    "@types/node": "^20.14.2",
    "@types/react": "^18.3.3",
    "@types/react-dom": "^18.3.0",
    "@types/ws": "^8.5.10",
    "@vitejs/plugin-react": "^4.3.0",
    "concurrently": "^8.2.2",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "tsx": "^4.15.2",
    "typescript": "^5.4.5",
    "vite": "^5.2.13"
  }
}

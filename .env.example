# Live Project Intelligence Dashboard - Environment Config

# Project to analyze (default: Paperclip repo)
PROJECT_ROOT=/home/paperclip/paperclip

# Dashboard server port
PORT=3456

# Paperclip API connection
PAPERCLIP_API_URL=http://localhost:3100
PAPERCLIP_WS_URL=ws://localhost:3100

# Required: Your Paperclip company ID for live events
# Get this from the Paperclip UI or API
PAPERCLIP_COMPANY_ID=

# Optional: API key if Paperclip requires auth
PAPERCLIP_API_KEY=

# GitHub Integration (for issue failure detection)
GITHUB_TOKEN=ghp_your_personal_access_token_here
GITHUB_OWNER=nehaaagre16-create
GITHUB_REPO=Bug-reporter-dashboard
